<div class="relative bg-white" x-data="{ mobileMenuOpen: false }">
  <div class="mx-auto px-4 sm:px-6">
    <div class="flex justify-between items-center py-6 md:justify-start md:space-x-10">
      <!-- STORE NAME / STORE LOGO -->
      <div class="absolute left-1/2 transform -translate-x-1/2">
        <h1 class="text-xl font-bold truncate text-center">
          {{ section.settings.logoplaceholder }}
        </h1>
      </div>
      <div class="md:hidden mr-auto">
        <button
          @click="mobileMenuOpen = true"
          type="button"
          class="bg-white p-2 inline-flex items-center justify-center focus:outline-none">
          {% render 'icon-hamburger' %}
        </button>
      </div>


      <!-- NAVIGATION MENU -->
      <nav x-data="{open:false}" class="hidden md:flex space-x-10">
        {% for link in linklists.main-menu.links %}
          {% if link.links != blank %}
            <div class="relative group">
              <button
                x-on:click="open = ! open"
                type="button"
                class="inline-flex items-center text-base text-gray-500 hover:text-gray-900">
                {{ link.title }}
                {% render 'icon-bottomarrow' %}
              </button>
              <div x-show="open" class="absolute z-10 -ml-5 mt-5 transform px-2 w-screen max-w-md sm:px-0 lg:ml-0 lg:left-1/2 lg:-translate-x-1/2">
                <div class="shadow-lg border ring-black ring-opacity-5 overflow-hidden rounded-lg">
                  <div class="relative grid gap-6 bg-white px-5 py-6 sm:gap-8 sm:p-8">

                    <!-- CREATE THE SUBLINK -->
                    <a class="-m-3 p-3 flex items start rounded-lg hover:bg-gray-100">
                      <div class="ml-4">
                        <p class="text-gray-900 text-base font-medium">
                          Sublink 1
                        </p>
                      </div>
                    </a>

                    <a class="-m-3 p-3 flex items start rounded-lg hover:bg-gray-100">
                      <div class="ml-4">
                        <p class="text-gray-900 text-base font-medium">
                          Sublink 2
                        </p>
                      </div>
                    </a>

                    <a class="-m-3 p-3 flex items start rounded-lg hover:bg-gray-100">
                      <div class="ml-4">
                        <p class="text-gray-900 text-base font-medium">
                          Sublink 3
                        </p>
                      </div>
                    </a>

                  </div>
                </div>
              </div>

              <div class="absolute left-0 mt-1 w-56 hidden group-hover:block hover:block pt-1">
                <div class="bg-white shadow-lg">
                  <div class="py-2">
                    {% for childlink in link.links %}
                      <a href="{{ childlink.url }}" class="block px-6 py-3 text-sm font-medium text-gray-900 hover:bg-gray-100 uppercase">
                        {{ childlink.title }}
                      </a>
                    {% endfor %}
                  </div>
                </div>
              </div>
            </div>
          {% else %}
            <div class="relative">
              <a href="{{ link.url }}" class="text-base text-gray-500 hover:text-gray-900">{{ link.title }}</a>
            </div>
          {% endif %}
        {% endfor %}


      </nav>

      <div class="hidden md:flex items-center justify-end md:flex-1 space-x-5">
        <a href="{{routes.cart_url}}" class="whitespace-nowrap text-base text-gray-500 hover:text-gray-900">
          {% render 'icon-shopping-bag' %}
        </a>

        <a href="{{ routes.account_login_url }}" class="text-base text-gray-500 hover:text-gray-900">Login</a>
        <a href="{{ routes.account_register_url }}" class="text-base text-gray-500 hover:text-gray-900">Register</a>
      </div>
    </div>
  </div>

  <!-- MOBILE MENU DRAWER -->
  <div
    x-show="mobileMenuOpen"
    class="fixed inset-0 z-50 md:hidden"
    x-cloak>
    <!-- Backdrop -->
    <div
      @click="mobileMenuOpen = false"
      x-show="mobileMenuOpen"
      x-transition:enter="transition-opacity ease-linear duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition-opacity ease-linear duration-300"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      class="fixed inset-0 bg-black bg-opacity-25"></div>

    <!-- Drawer Panel -->
    <div
      x-show="mobileMenuOpen"
      x-transition:enter="transition ease-in-out duration-300 transform"
      x-transition:enter-start="-translate-x-full"
      x-transition:enter-end="translate-x-0"
      x-transition:leave="transition ease-in-out duration-300 transform"
      x-transition:leave-start="translate-x-0"
      x-transition:leave-end="-translate-x-full"
      class="fixed inset-0 bg-white">

      <div class="h-full flex flex-col">
        <!-- MOBILE MENU HEADER -->
        <div class="grid grid-cols-2 gap-4 px-6 py-6 border-b border-gray-200">
          <div class="text-left">
            <h1 class="text-base font-medium text-gray-600 uppercase">Menu</h1>
          </div>
          <div class="text-right">
            <button
              @click="mobileMenuOpen = false"
              type="button"
              class="text-base font-medium text-gray-400 hover:text-gray-600 uppercase">
              {% render "close-icon" %}
            </button>
          </div>
        </div>

        <!-- NAVIGATION LINKS -->
        <div class="flex-1 overflow-y-auto px-6 py-8">
          <nav class="space-y-6">


            {% for link in linklists.main-menu.links %}
              {% if link.links != blank %}
                <div class="space-y-4" x-data="{ open: false }">
                  <div class="flex items-center justify-between">
                    <a href="{{ link.url }}" class="text-base text-gray-700 hover:text-gray-900">
                      {{ link.title }}
                    </a>
                    <button
                      type="button"
                      class="inline-flex items-center text-gray-500 hover:text-gray-900"
                      @click="open = !open"
                      aria-label="Toggle submenu">
                      <span :class="{ 'rotate-180': open }" class="transition-transform duration-200">
                        {% render "icon-bottomarrow" %}
                      </span>
                    </button>
                  </div>
                  <div x-show="open" class="space-y-3">
                    {% for childlink in link.links %}
                      <a href="{{ childlink.url }}" class="block text-base text-gray-500 hover:text-gray-900">
                        {{ childlink.title }}
                      </a>
                    {% endfor %}
                  </div>
                </div>
              {% else %}
                <a href="{{ link.url }}" class="block text-base text-gray-700 hover:text-gray-900">
                  {{ link.title }}
                </a>
              {% endif %}
            {% endfor %}


          </nav>
        </div>
      </div>
    </div>
  </div>
</div>
{% schema %}
  {
    "name": "Header",
    "settings": [
      {
        "type": "header",
        "content": "Title"
      }, 
      {
        "type": "text",
        "id": "logoplaceholder",
        "label": "Title",
        "default": "Mourad Theme"
      }
    ]
  }
{% endschema %}